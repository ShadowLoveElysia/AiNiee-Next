{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window and local web host.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  }
}
